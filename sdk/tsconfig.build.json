{
	"extends": "@tsconfig/node20/tsconfig.json",
	"compilerOptions": {
		"preserveConstEnums": true,
		"declaration": true,
		"declarationMap": true,
		"outDir": "./dist",
		"rootDir": "./src"
	},
	"include": ["src/**/*.ts"],
	"exclude": [
		"**/*.test.ts",
		"node_modules",
		"coverage",
		"**/__mocks__/*",
		"dist"
	]
}
